  "descriptions": [
    {
      "text": "Game Boy Advance port of Need for Speed: Most Wanted offers a scaled-down yet distinct take on the iconic street racing title. It features a mix of circuit and sprint races, and a simplified version of the main game's “Blacklist” system.",
