  "descriptions": [
    {
      "text": "Pro Wrestling is a pro wrestling video game developed and published by Nintendo. The game was the third wrestling game on the Nintendo Entertainment System (after M.U.S.C.L.E. and Tag Team Wrestling). It is one of Nintendo's sports-themed games for the NES, alongside titles like Tennis, Golf, Soccer, Volleyball and Ice Hockey.",
      "lang": "en",
      "source": "igdb"
    },
