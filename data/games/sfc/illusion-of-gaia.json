    },
    {
      "text": "1993 video game",
      "lang": "en",
      "source": "wikidata"
    },
    {
      "text": "videojuego de 1993",
      "lang": "es",
      "source": "wikidata"
    },
    {
      "text": "jeu vidéo de 1993",
      "lang": "fr",
