  "descriptions": [
    {
      "text": "In Pokémon Dash, you'll control Pikachu and race against other Pokémon. Use the DS's touch screen to adjust Pikachu's direction and speed. Off the course, Pikachu can cross water terrain by riding on Lapras' back and fly using a hot-air balloon.",
      "lang": "en",
      "source": "igdb"
    },
