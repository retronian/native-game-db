    {
      "text": "videogioco del 2006",
      "lang": "it",
      "source": "wikidata"
    },
    {
      "text": "компьютерная игра 2006 года",
      "lang": "ru",
      "source": "wikidata"
    },
    {
      "text": "jogo eletrônico de 2006",
      "lang": "pt",
