  "descriptions": [
    {
      "text": "Fantastic Fortune is a romance simulation game.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "The story is set in medieval times, in the planet Warand.\nA raising sim where you take control of one of three protagonists over the space of a year.\n\nDiana is the second Princess of the Kingdom of Klein (her hobby is collecting hats).\nMei is a regular high school student from the human world who was accidentally summoned to the Royal Academy of Magic.\nSylphis is a knight apprentice from a race that chooses their gender once they start puberty.\n\nThe player's character will spend a year at Klein to achieve the proper magic abilities.\nTheir fate is in the hands of the player.",
      "lang": "en",
      "source": "igdb_storyline"
    },
