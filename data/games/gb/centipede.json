  "descriptions": [
    {
      "text": "The Game Boy port of the 1981 original has features enhancements for the Super Game Boy.",
      "lang": "en",
      "source": "igdb"
    },
    {
      "text": "In Centipede, the player is trapped in the Enchanted Forest. Armed with only a magic wand to ward off the forest's insect denizens, all of which apparently are attacking in the player in continuous waves.\n\nThe player must use the magic wand to shoot sparks at approaching insects to score points by pressing the controller button. Holding down the controller button will set the wand to rapid fire shots. If the player is bitten by an insect, the player will be temporarily paralyzed and lose one of the three starting magic wands.",
      "lang": "en",
      "source": "igdb_storyline"
    },
